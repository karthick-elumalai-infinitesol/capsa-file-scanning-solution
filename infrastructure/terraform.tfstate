            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"S3StagingRead\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"s3:GetObjectVersion\",\n        \"s3:GetObject\"\n      ],\n      \"Resource\": \"arn:aws:s3:::capsa-staging-203733861310/*\"\n    },\n    {\n      \"Sid\": \"S3CleanWrite\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"s3:PutObjectTagging\",\n        \"s3:PutObject\",\n        \"s3:CopyObject\"\n      ],\n      \"Resource\": \"arn:aws:s3:::capsa-clean-203733861310/*\"\n    },\n    {\n      \"Sid\": \"S3QuarantineWrite\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"s3:PutObjectTagging\",\n        \"s3:PutObject\"\n      ],\n      \"Resource\": \"arn:aws:s3:::capsa-quarantine-203733861310/*\"\n    },\n    {\n      \"Sid\": \"KMSDecrypt\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"kms:GenerateDataKey\",\n        \"kms:DescribeKey\",\n        \"kms:Decrypt\"\n      ],\n      \"Resource\": [\n        \"arn:aws:kms:us-east-2:203733861310:key/bcaa2f8c-b9c6-45ce-99ed-258fefc018a0\",\n        \"arn:aws:kms:us-east-2:203733861310:key/6438f468-24a5-48c2-9046-a5ed62d273a2\"\n      ]\n    },\n    {\n      \"Sid\": \"CloudWatchLogs\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"logs:PutLogEvents\",\n        \"logs:CreateLogStream\"\n      ],\n      \"Resource\": \"arn:aws:logs:us-east-2:203733861310:*\"\n    },\n    {\n      \"Sid\": \"InvokeRoutingLambda\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"lambda:InvokeFunction\",\n      \"Resource\": \"arn:aws:lambda:us-east-2:203733861310:function:capsa-prod-file-routing-engine\"\n    },\n    {\n      \"Sid\": \"SNSPublish\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"sns:Publish\",\n      \"Resource\": \"arn:aws:sns:us-east-2:203733861310:capsa-security-alerts\"\n    }\n  ]\n}",
