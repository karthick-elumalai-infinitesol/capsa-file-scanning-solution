# =============================================================================
# CAPSA Enterprise Scanner — Environment Configuration
# Copy to .env and fill in your values
# =============================================================================

# ── AWS Configuration ─────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
S3_BUCKET=your-bucket-name

# AWS Enterprise Integrations — set to true to enable
AWS_GUARDDUTY_ENABLED=false
AWS_INSPECTOR_ENABLED=false
AWS_SECURITYHUB_ENABLED=false

# S3 staging/clean/quarantine buckets (used by Lambda routing)
AWS_STAGING_BUCKET=
AWS_CLEAN_BUCKET=
AWS_QUARANTINE_BUCKET=

# ── VirusTotal Configuration ─────────────────────────────────────────────
VIRUSTOTAL_API_KEY=your_virustotal_key_here

# ── NSRL Configuration ───────────────────────────────────────────────────
NSRL_DATABASE_PATH=./data/nsrl.db

# ── Jira Configuration ───────────────────────────────────────────────────
JIRA_URL=https://your-org.atlassian.net
JIRA_USERNAME=your.name@your-org.com
JIRA_API_TOKEN=your_jira_token_here
JIRA_PROJECT_KEY=SEC

# ── ClamAV Configuration ─────────────────────────────────────────────────
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT=30
# Recommended Docker image tag: clamav/clamav:1.5.2-debian13-slim

# ── DefectDojo Configuration (Enterprise VM) ─────────────────────────────
DEFECTDOJO_URL=https://defectdojo.your-org.com
DEFECTDOJO_API_KEY=your_defectdojo_api_key_here
DEFECTDOJO_PRODUCT_NAME=CAPSA-Scanner
DEFECTDOJO_ENGAGEMENT_NAME=Auto-Scan
DEFECTDOJO_AUTO_IMPORT=true

# ── Scanner Configuration ────────────────────────────────────────────────
MAX_WORKERS=20
LOG_LEVEL=INFO
MAX_FILE_SIZE_MB=100
BATCH_SIZE=500

# Queue Configuration (for large-scale scanning)
# Backend: "redis" for local dev, "sqs" for AWS production
QUEUE_BACKEND=redis
REDIS_URL=redis://redis:6379/0
SQS_QUEUE_NAME=capsa-scan-queue
SQS_DLQ_NAME=capsa-scan-dlq
QUEUE_WORKER_CONCURRENCY=4
QUEUE_VISIBILITY_TIMEOUT=120
QUEUE_MAX_RETRIES=3

# S3 Polling for large datasets
ENABLE_S3_POLLING=false
S3_POLLING_INTERVAL_SECONDS=300

# ── API Configuration ────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
ENABLE_CACHE=true
